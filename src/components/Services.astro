---
const services = [
  {
    title: 'Battery Replacement',
    description: 'Fast on-site battery supply and installation for all vehicle types across UAE.',
    image: '/battery-change.jpg',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="1" y="6" width="18" height="13" rx="2"/><path d="M23 11v3"/><path d="M7 10v5M10 10v5"/></svg>`,
  },
  {
    title: 'Flat Tire Assistance',
    description: 'Quick on-site puncture repair or spare tire installation anywhere in UAE.',
    image: '/flat-tyre.jpg',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/></svg>`,
  },
  {
    title: 'Emergency Fuel Delivery',
    description: 'Petrol or diesel delivered directly to your location, 24 hours a day.',
    image: '/fuel-fill.jpg',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 22V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v10"/><path d="M15 8h2l3 3v5a1 1 0 0 1-1 1h-4V8z"/><path d="M3 22h12"/><path d="M7 6h4"/></svg>`,
  },
  {
    title: 'Mobile Oil Change',
    description: 'Professional car maintenance and oil change at your location — no garage needed.',
    image: '/oil-change.jpg',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>`,
  },
  {
    title: 'System Diagnosis & Repairs',
    description: 'Expert mobile mechanic for minor repairs, electrical fixes, and full diagnostics.',
    image: '/scan.jpg',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    title: 'AC Gas Refill',
    description: 'On-demand AC gas refill service. Stay cool with fast, efficient car AC servicing.',
    image: '/ac-gas-filling.jpg',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="12" y1="2" x2="12" y2="22"/><path d="m20 6-8 4-8-4"/><path d="m4 6 8 4 8-4"/><line x1="2" y1="12" x2="22" y2="12"/><path d="m20 18-8-4-8 4"/></svg>`,
  },
  {
    title: 'Towing & Recovery',
    description: 'Reliable car towing for breakdowns and accidents. Safe vehicle transport anytime.',
    image: '/towing.jpg',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M1 3h15v10H1z"/><path d="M16 8h4l3 3v4h-7V8z"/><circle cx="5.5" cy="17.5" r="2.5"/><circle cx="18.5" cy="17.5" r="2.5"/></svg>`,
  },
];
---

<section id="services" class="py-24 md:py-32 bg-[#0B0B0B] relative overflow-hidden">

  <div class="max-w-7xl mx-auto px-5 md:px-10">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="reveal inline-flex items-center gap-2 text-amber-400 text-xs font-bold uppercase tracking-widest mb-5">
        <span class="w-6 h-px bg-amber-400"></span>
        What We Do
        <span class="w-6 h-px bg-amber-400"></span>
      </div>
      <h2 class="reveal text-3xl md:text-4xl lg:text-5xl font-extrabold leading-tight" style="transition-delay:0.1s;">
        Our Roadside Assistance<br />
        <span class="text-amber-400">Services in UAE</span>
      </h2>
      <p class="reveal text-white/50 text-base md:text-lg mt-4 max-w-xl mx-auto" style="transition-delay:0.2s;">
        From dead batteries to full vehicle recovery—we handle every roadside emergency
        quickly and professionally.
      </p>
    </div>

    <!-- Marquee container -->
    <div class="overflow-hidden reveal" style="transition-delay:0.3s;">
      <div class="marquee-track gap-5 py-2">
        <!-- First set -->
        {services.map((service) => (
          <div class="flex-shrink-0 w-72 md:w-80 h-96 relative rounded-2xl overflow-hidden group cursor-default shadow-[0_4px_24px_rgba(0,0,0,0.4)] hover:shadow-[0_8px_40px_rgba(0,0,0,0.6)] transition-all duration-500 hover:-translate-y-2">
            <!-- Image -->
            <img
              src={service.image}
              alt={service.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10"></div>
            <!-- Hover amber tint -->
            <div class="absolute inset-0 bg-amber-400/0 group-hover:bg-amber-400/8 transition-colors duration-500"></div>
            <!-- Content -->
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <!-- Icon badge -->
              <div class="w-10 h-10 bg-amber-400 rounded-xl flex items-center justify-center text-black mb-4 shadow-[0_4px_16px_rgba(245,158,11,0.4)]">
                <Fragment set:html={service.icon} />
              </div>
              <h3 class="text-base font-bold text-white mb-1.5">{service.title}</h3>
              <p class="text-white/55 text-sm leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
        <!-- Duplicate for seamless loop -->
        {services.map((service) => (
          <div class="flex-shrink-0 w-72 md:w-80 h-96 relative rounded-2xl overflow-hidden group cursor-default shadow-[0_4px_24px_rgba(0,0,0,0.4)] hover:shadow-[0_8px_40px_rgba(0,0,0,0.6)] transition-all duration-500 hover:-translate-y-2">
            <!-- Image -->
            <img
              src={service.image}
              alt={service.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10"></div>
            <!-- Hover amber tint -->
            <div class="absolute inset-0 bg-amber-400/0 group-hover:bg-amber-400/8 transition-colors duration-500"></div>
            <!-- Content -->
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <!-- Icon badge -->
              <div class="w-10 h-10 bg-amber-400 rounded-xl flex items-center justify-center text-black mb-4 shadow-[0_4px_16px_rgba(245,158,11,0.4)]">
                <Fragment set:html={service.icon} />
              </div>
              <h3 class="text-base font-bold text-white mb-1.5">{service.title}</h3>
              <p class="text-white/55 text-sm leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12 reveal" style="transition-delay:0.4s;">
      <a
        href="tel:8002477"
        class="inline-flex items-center gap-2 bg-amber-400 hover:bg-amber-500 text-black font-bold px-8 py-4 rounded-full transition-all duration-200 hover:scale-105"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.58.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.01L6.6 10.8z"/>
        </svg>
        Request Assistance – Call 800 2477
      </a>
    </div>

  </div>
</section>
