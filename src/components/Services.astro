---

<section id="services" class="py-24 md:py-32 bg-[#0B0B0B] relative">

  <div class="max-w-7xl mx-auto px-5 md:px-10">

    <!-- Section header -->
    <div class="text-center mb-12">
      <div class="reveal inline-flex items-center gap-2 text-amber-400 text-xs font-bold uppercase tracking-widest mb-5">
        <span class="w-6 h-px bg-amber-400"></span>
        What We Do
        <span class="w-6 h-px bg-amber-400"></span>
      </div>
      <h2 class="reveal text-3xl md:text-4xl lg:text-5xl font-extrabold leading-tight" style="transition-delay:0.1s;">
        Our Roadside Assistance<br />
        <span class="text-amber-400">Services</span>
      </h2>
      <p class="reveal text-white/50 text-base md:text-lg mt-4 max-w-xl mx-auto" style="transition-delay:0.2s;">
        From dead batteries to full vehicle recovery—we handle every roadside emergency
        quickly and professionally.
      </p>
    </div>

    <!-- Service nav pills -->
    <div class="reveal mb-10 overflow-x-auto pb-2 -mx-5 px-5 md:mx-0 md:px-0" style="transition-delay:0.3s;">
      <div class="flex items-center gap-2.5 w-fit md:flex-wrap md:justify-center" id="service-nav">
        {services.map((service, i) => (
          <button
            data-index={i}
            data-id={service.id}
            class:list={[
              'service-pill flex-shrink-0 flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold border transition-all duration-200 whitespace-nowrap',
              i === 0
                ? 'bg-amber-400 text-black border-amber-400'
                : 'bg-transparent text-white/60 border-white/20 hover:border-amber-400/50 hover:text-white',
            ]}
          >
            <span class="opacity-80 flex-shrink-0"><Fragment set:html={service.icon} /></span>
            {service.title}
          </button>
        ))}
      </div>
    </div>

    <!-- Carousel -->
    <div class="reveal" style="transition-delay:0.4s;">
      <div id="carousel-wrapper" class="relative overflow-hidden rounded-3xl">
        <div id="carousel-track" class="flex" style="transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
          {services.map((service, i) => (
            <div class="w-full flex-shrink-0 min-h-[88vh] flex flex-col md:flex-row bg-white/[0.03] border border-white/10 rounded-3xl overflow-hidden">

              <!-- Left: image in curved card -->
              <div class="md:w-[48%] p-4 md:p-5 flex-shrink-0">
                <div class="relative h-60 md:h-full rounded-2xl overflow-hidden">
                  <img
                    src={service.image}
                    alt={service.title}
                    class="absolute inset-0 w-full h-full object-cover"
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent md:bg-gradient-to-r md:from-transparent md:to-[#0B0B0B]/40"></div>
                </div>
              </div>

              <!-- Right: service info -->
              <div class="md:w-[52%] flex flex-col justify-center p-8 md:p-10 lg:p-14">

                <div class="w-12 h-12 bg-amber-400 rounded-2xl flex items-center justify-center text-black mb-6 shadow-[0_4px_20px_rgba(245,158,11,0.3)]">
                  <Fragment set:html={service.icon} />
                </div>

                <h3 class="text-2xl md:text-3xl lg:text-4xl font-extrabold text-white mb-4 leading-tight">
                  {service.title}
                </h3>

                <p class="text-white/55 text-sm md:text-base leading-relaxed mb-8">
                  {service.description}
                </p>

                <ul class="space-y-3 mb-10">
                  {service.highlights.map((point) => (
                    <li class="flex items-start gap-3 text-white/75 text-sm md:text-base">
                      <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-amber-400/15 border border-amber-400/30 flex items-center justify-center">
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                          <path d="M2 5.5l2 2L8 3" stroke="#FBBF24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      {point}
                    </li>
                  ))}
                </ul>

                <div>
                  <a
                    href="tel:8002477"
                    class="inline-flex items-center gap-2.5 bg-amber-400 hover:bg-amber-500 text-black font-bold px-6 py-3.5 rounded-full text-sm transition-all duration-200 hover:scale-105 shadow-[0_4px_20px_rgba(245,158,11,0.25)]"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.58.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.01L6.6 10.8z"/>
                    </svg>
                    Call 800 2477 Now
                  </a>
                </div>

              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Dot indicators -->
      <div class="flex justify-center items-center gap-2 mt-6">
        {services.map((_, i) => (
          <button
            class:list={[
              'carousel-dot transition-all duration-300 rounded-full',
              i === 0 ? 'w-7 h-2 bg-amber-400' : 'w-2 h-2 bg-white/25 hover:bg-white/50',
            ]}
            data-index={i}
            aria-label={`Go to service ${i + 1}`}
          />
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const track = document.getElementById('carousel-track') as HTMLElement;
  const wrapper = document.getElementById('carousel-wrapper') as HTMLElement;
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>('.service-pill'));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.carousel-dot'));
  const total = pills.length;

  let current = 0;
  let autoplayTimer: ReturnType<typeof setInterval> | null = null;
  let touchStartX = 0;

  function goTo(index: number) {
    // Wrap around for infinity effect
    current = ((index % total) + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    updateDots();
    updatePills();
  }

  function updateDots() {
    dots.forEach((dot, i) => {
      const active = i === current;
      dot.classList.toggle('w-7', active);
      dot.classList.toggle('bg-amber-400', active);
      dot.classList.toggle('w-2', !active);
      dot.classList.toggle('bg-white/25', !active);
    });
  }

  function updatePills() {
    pills.forEach((pill, i) => {
      const active = i === current;
      pill.classList.toggle('bg-amber-400', active);
      pill.classList.toggle('text-black', active);
      pill.classList.toggle('border-amber-400', active);
      pill.classList.toggle('bg-transparent', !active);
      pill.classList.toggle('text-white/60', !active);
      pill.classList.toggle('border-white/20', !active);
    });
  }

  function startAutoplay() {
    stopAutoplay();
    autoplayTimer = setInterval(() => goTo(current + 1), 5000);
  }

  function stopAutoplay() {
    if (autoplayTimer) clearInterval(autoplayTimer);
    autoplayTimer = null;
  }

  function resetAutoplay() {
    startAutoplay();
  }

  // Dot clicks
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      goTo(Number(dot.getAttribute('data-index')));
      resetAutoplay();
    });
  });

  // Pill clicks
  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      goTo(Number(pill.getAttribute('data-index')));
      resetAutoplay();
      // Scroll carousel into view if needed
      wrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });

  // Pause autoplay on hover
  wrapper.addEventListener('mouseenter', stopAutoplay);
  wrapper.addEventListener('mouseleave', startAutoplay);

  // Touch swipe support
  wrapper.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    stopAutoplay();
  }, { passive: true });

  wrapper.addEventListener('touchend', (e) => {
    const delta = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(delta) > 50) goTo(delta > 0 ? current + 1 : current - 1);
    startAutoplay();
  }, { passive: true });

  // Init
  goTo(0);
  startAutoplay();
</script>
