---
const reasons = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: '24/7 Availability',
    description: 'Always ready to help—day or night, weekends and public holidays. No waiting, no delays.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    title: 'Fast Response Time',
    description: 'Our technicians are strategically positioned to reach you in under 30 minutes.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    title: 'Expert Technicians',
    description: 'Skilled, certified mechanics with over 10 years of combined field experience.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Wide UAE Coverage',
    description: 'Serving Dubai, Abu Dhabi, Sharjah, and Ajman—wherever you are, we come to you.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Reliable & Trusted',
    description: 'Over 10,000 happy customers trust us for dependable, professional roadside care.',
  },
];
---

<section id="why-us" class="py-24 md:py-32 bg-[#0B0B0B] relative overflow-hidden">

  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-amber-500/3 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-5 md:px-10">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="reveal inline-flex items-center gap-2 text-amber-400 text-xs font-bold uppercase tracking-widest mb-5">
        <span class="w-6 h-px bg-amber-400"></span>
        Why Choose Us
        <span class="w-6 h-px bg-amber-400"></span>
      </div>
      <h2 class="reveal text-3xl md:text-4xl lg:text-5xl font-extrabold leading-tight" style="transition-delay:0.1s;">
        Why We're the Preferred<br />
        <span class="text-amber-400">Roadside Assistance in UAE</span>
      </h2>
    </div>

    <!-- 5-item grid: 3 top + 2 bottom centered -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">
      {reasons.map((r, i) => (
        <div
          class="reveal bg-[#0B0B0B]/60 border border-white/8 hover:border-amber-400/30 rounded-2xl p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(0,0,0,0.4)] group"
          style={`transition-delay: ${i * 0.1}s;`}
        >
          <div class="w-11 h-11 bg-amber-400/10 group-hover:bg-amber-400/15 rounded-xl flex items-center justify-center text-amber-400 mb-5 transition-colors">
            <Fragment set:html={r.icon} />
          </div>
          <h3 class="text-base font-bold text-white mb-2">{r.title}</h3>
          <p class="text-white/50 text-sm leading-relaxed">{r.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
