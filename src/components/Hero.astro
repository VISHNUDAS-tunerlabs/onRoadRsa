---
---

<section id="home" class="relative min-h-screen flex items-center overflow-hidden">

  <!-- Background -->
  <div class="absolute inset-0 bg-[#0B0B0B]">
    <!-- Hero image -->
    <picture class="absolute inset-0 w-full h-full">
      <source
        media="(max-width: 767px)"
        srcset={`${import.meta.env.BASE_URL}main_banner_mobile.png`}
      />
      <img
        src={`${import.meta.env.BASE_URL}car-breakdown-main.jpeg`}
        alt="Roadside assistance technician helping a stranded driver"
        class="absolute inset-0 w-full h-full object-cover object-center opacity-90"
        loading="eager"
      />
    </picture>
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-gradient-to-r from-[#0B0B0B]/75 via-[#0B0B0B]/35 to-transparent"></div>
    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-[#0B0B0B] to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-10 w-full pt-28 md:pt-36 pb-20">
    <div class="max-w-3xl">

      <!-- Availability badge -->
      <div
        class="inline-flex items-center gap-2 bg-green-400/10 border border-green-400/40 text-green-400 text-xs font-semibold px-4 py-1.5 rounded-full mb-7 opacity-0 shadow-[0_0_16px_2px_rgba(74,222,128,0.2)]"
        style="animation: fadeUp 0.5s 0.1s ease forwards;"
      >
        <span class="w-2 h-2 rounded-full bg-green-400 flex-shrink-0 shadow-[0_0_8px_2px_rgba(74,222,128,0.7)] animate-pulse"></span>
        Available 24/7 &middot; UAE Coverage
      </div>

      <!-- H1 -->
      <h1
        class="text-4xl md:text-6xl lg:text-[4.5rem] font-extrabold leading-[1.1] tracking-tight mb-5 opacity-0"
        style="animation: fadeUp 0.6s 0.2s ease forwards;"
      >
        On Call<br />
        <span class="text-amber-400">Roadside Assistance</span>
      </h1>

      <!-- H2 -->
      <h2
        class="text-lg md:text-xl font-medium text-white/55 mb-6 leading-relaxed opacity-0"
        style="animation: fadeUp 0.6s 0.35s ease forwards;"
      >
        Fast, reliable car breakdown support across<br class="hidden sm:block" />
        Dubai, Abu Dhabi, Sharjah &amp; Ajman
      </h2>

      <!-- Description -->
      <p
        class="text-base md:text-lg text-white/45 max-w-xl mb-10 leading-relaxed opacity-0"
        style="animation: fadeUp 0.6s 0.45s ease forwards;"
      >
        Stranded on the road? Our expert technicians reach you quickly—battery,
        tire, fuel, towing &amp; more. Anytime, anywhere.
      </p>

      <!-- CTA buttons -->
      <div
        class="flex flex-col sm:flex-row gap-4 opacity-0"
        style="animation: fadeUp 0.6s 0.55s ease forwards;"
      >
        <a
          href="tel:8002477"
          class="inline-flex items-center justify-center gap-2.5 bg-amber-400 hover:bg-amber-500 text-black font-bold text-base px-8 py-4 rounded-full transition-all duration-200 shadow-[0_0_32px_rgba(245,158,11,0.25)] hover:shadow-[0_0_40px_rgba(245,158,11,0.45)] hover:scale-105 active:scale-100"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.58.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.01L6.6 10.8z"/>
          </svg>
          Call Now: 800 2477
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center gap-2 border border-white/20 hover:border-amber-400/40 text-white/80 hover:text-white font-semibold text-base px-8 py-4 rounded-full transition-all duration-200 hover:bg-white/5"
        >
          Our Services
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <!-- Trust signals -->
      <div
        class="flex flex-wrap items-center gap-x-7 gap-y-3 mt-14 opacity-0"
        style="animation: fadeUp 0.6s 0.7s ease forwards;"
      >
        <div class="flex items-center gap-2 text-white/40 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-green-400 flex-shrink-0">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          Fast Response Time
        </div>
        <div class="flex items-center gap-2 text-white/40 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-green-400 flex-shrink-0">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Certified Technicians
        </div>
        <div class="flex items-center gap-2 text-white/40 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-green-400 flex-shrink-0">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          UAE-Wide Coverage
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 opacity-0"
    style="animation: fadeUp 0.6s 1s ease forwards;"
  >
    <span class="text-white/25 text-xs font-medium tracking-[0.2em] uppercase">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-white/20 to-transparent"></div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
