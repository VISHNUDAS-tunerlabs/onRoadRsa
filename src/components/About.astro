---
---

<section id="about" class="py-24 md:py-32 bg-[#0B0B0B] relative overflow-hidden">

  <!-- Background accent -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-amber-500/4 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-blue-600/4 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-5 md:px-10">
    <div class="grid md:grid-cols-2 gap-16 md:gap-20 items-center">

      <!-- Left: Content -->
      <div>
        <div class="reveal flex items-center gap-2 text-amber-400 text-xs font-bold uppercase tracking-widest mb-5">
          <span class="w-6 h-px bg-amber-400 flex-shrink-0"></span>
          About Us
        </div>

        <h2 class="reveal text-3xl md:text-4xl lg:text-5xl font-extrabold leading-[1.15] mb-6" style="transition-delay: 0.1s;">
          Trusted Roadside<br />
          <span class="text-amber-400">Assistance Partner</span><br />
          in UAE
        </h2>

        <p class="reveal text-white/60 text-base md:text-lg leading-relaxed mb-5" style="transition-delay: 0.2s;">
          At Oncall Roadside Assistance, we understand that vehicle breakdowns
          can happen anytime—and often when you least expect them. That's why we
          provide <span class="text-white/90 font-medium">24/7 roadside assistance services across the UAE</span>,
          ensuring you're never left stranded.
        </p>

        <p class="reveal text-white/55 text-base leading-relaxed mb-10" style="transition-delay: 0.3s;">
          Our team of <span class="text-white/90 font-medium">certified and experienced technicians</span> is
          equipped to handle everything from battery replacement and flat tire
          repair to fuel delivery and minor mechanical fixes.
        </p>

        <div class="reveal flex flex-wrap gap-4" style="transition-delay: 0.4s;">
          <a
            href="tel:8002477"
            class="inline-flex items-center gap-2 bg-amber-400 hover:bg-amber-500 text-black font-bold px-6 py-3 rounded-full transition-colors duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.58.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.01L6.6 10.8z"/>
            </svg>
            Call 800 2477
          </a>
          <a
            href="#services"
            class="inline-flex items-center gap-2 border border-white/20 hover:border-white/40 text-white/70 hover:text-white font-semibold px-6 py-3 rounded-full transition-colors duration-200"
          >
            View Services
          </a>
        </div>
      </div>

      <!-- Right: Stats + Quote -->
      <div class="reveal" style="transition-delay: 0.2s;">
        <!-- 2x2 stats grid -->
        <div class="grid grid-cols-2 gap-3 mb-3">
          <div class="bg-amber-400 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(245,158,11,0.4)] group">
            <div class="w-11 h-11 bg-black/10 rounded-xl flex items-center justify-center text-black mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="text-2xl md:text-3xl font-extrabold text-black mb-1">&lt; 30 min</div>
            <div class="text-black/80 text-sm font-semibold leading-snug">Average Response Time</div>
          </div>
          <div class="bg-amber-400 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(245,158,11,0.4)] group">
            <div class="w-11 h-11 bg-black/10 rounded-xl flex items-center justify-center text-black mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <div class="text-2xl md:text-3xl font-extrabold text-black mb-1">10+ Yrs</div>
            <div class="text-black/80 text-sm font-semibold leading-snug">Industry Experience</div>
          </div>
          <div class="bg-amber-400 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(245,158,11,0.4)] group">
            <div class="w-11 h-11 bg-black/10 rounded-xl flex items-center justify-center text-black mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="text-2xl md:text-3xl font-extrabold text-black mb-1">4 Emirates</div>
            <div class="text-black/80 text-sm font-semibold leading-snug">UAE Coverage Area</div>
          </div>
          <div class="bg-amber-400 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(245,158,11,0.4)] group">
            <div class="w-11 h-11 bg-black/10 rounded-xl flex items-center justify-center text-black mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div class="text-2xl md:text-3xl font-extrabold text-black mb-1">10,000+</div>
            <div class="text-black/80 text-sm font-semibold leading-snug">Happy Customers</div>
          </div>
        </div>

        <!-- Quote card -->
        <div class="bg-amber-400/5 border border-amber-400/20 rounded-2xl p-6">
          <p class="text-white/65 text-sm leading-relaxed italic">
            "Our goal is simple:&nbsp;
            <span class="text-amber-400 font-semibold not-italic">get you back on the road safely and quickly.</span>"
          </p>
          <div class="flex items-center gap-3 mt-4">
            <div class="w-9 h-9 bg-amber-400 rounded-full flex items-center justify-center text-black font-extrabold text-sm flex-shrink-0">
              O
            </div>
            <div>
              <div class="text-white/90 text-sm font-semibold">Oncall RSA Team</div>
              <div class="text-white/40 text-xs">International City, Dubai, UAE</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
