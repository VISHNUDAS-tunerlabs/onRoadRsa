---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat('en-AE', { day: 'numeric', month: 'long', year: 'numeric' });

const initials = (name: string) =>
  name.split(' ').map((w) => w[0]).join('').toUpperCase();

const heartIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-6.7-4.35-9.33-8.2C1.18 10.5 1.5 7.5 4 6c2-.9 4 .2 5 2 1-1.8 3-2.9 5-2 2.5 1.5 2.82 4.5 1.33 6.8C18.7 16.65 12 21 12 21z"/></svg>`;

const blogBase = `${import.meta.env.BASE_URL}blog`;
---

<Layout
  title={`${post.data.title} | OnCall RSA Blog`}
  description={post.data.excerpt}
  transitions
>
  <Header />
  <main>
    <article class="pt-28 pb-24 md:pt-36 md:pb-32 bg-[#0B0B0B] relative overflow-hidden">

      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-amber-500/3 rounded-full blur-3xl pointer-events-none"></div>

      <div class="max-w-3xl mx-auto px-5 md:px-10 relative">

        <!-- Back link -->
        <a
          href={`${blogBase}/`}
          class="inline-flex items-center gap-2 text-white/50 hover:text-amber-400 text-sm font-medium mb-8 transition-colors group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" class="transition-transform duration-200 group-hover:-translate-x-1">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          Back to Blog
        </a>

        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 text-amber-400 text-xs font-bold uppercase tracking-widest mb-5">
          <span class="w-6 h-px bg-amber-400"></span>
          OnCall RSA Blog
        </div>

        <!-- Title -->
        <h1
          class="text-2xl md:text-4xl lg:text-[2.75rem] font-extrabold leading-tight mb-6"
          transition:name={`blog-title-${post.slug}`}
        >
          {post.data.title}
        </h1>

        <!-- Meta row -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-3 text-sm text-white/45 mb-8 pb-8 border-b border-white/8">
          <div class="flex items-center gap-2.5">
            <span class="w-9 h-9 rounded-full bg-amber-400/15 text-amber-400 flex items-center justify-center font-bold text-xs flex-shrink-0">
              {initials(post.data.author)}
            </span>
            <div class="leading-tight">
              <p class="text-white/80 font-semibold text-sm">{post.data.author}</p>
              <a href={`mailto:${post.data.authorEmail}`} class="text-white/35 hover:text-amber-400 text-xs transition-colors">{post.data.authorEmail}</a>
            </div>
          </div>
          <span class="w-1 h-1 rounded-full bg-white/20 hidden sm:inline-block"></span>
          <span>{dateFormatter.format(post.data.publishDate)}</span>
          <span class="w-1 h-1 rounded-full bg-white/20 hidden sm:inline-block"></span>
          <span class="flex items-center gap-1.5 text-rose-400/70">
            <Fragment set:html={heartIcon} />
            {post.data.likes} likes
          </span>
        </div>

        <!-- Hero image -->
        <div class="relative h-56 md:h-80 rounded-2xl overflow-hidden mb-10 border border-white/10">
          <img
            src={`${import.meta.env.BASE_URL}${post.data.image}`}
            alt={post.data.title}
            class="absolute inset-0 w-full h-full object-cover"
            transition:name={`blog-image-${post.slug}`}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0B0B0B]/40 via-transparent to-transparent"></div>
        </div>

        <!-- Article content -->
        <div class="article-content">
          <Content />
        </div>

        <!-- CTA -->
        <div class="mt-12 bg-white/[0.03] border border-white/10 rounded-2xl p-7 md:p-9 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
          <div>
            <h3 class="text-lg md:text-xl font-bold text-white mb-1.5">Need help right now?</h3>
            <p class="text-white/50 text-sm">Our team is on call 24/7, anywhere across the UAE.</p>
          </div>
          <a
            href="tel:8002477"
            class="inline-flex items-center gap-2.5 bg-amber-400 hover:bg-amber-500 text-black font-bold px-6 py-3.5 rounded-full text-sm transition-all duration-200 hover:scale-105 shadow-[0_4px_20px_rgba(245,158,11,0.25)] flex-shrink-0"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.58.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.01L6.6 10.8z"/>
            </svg>
            Call 800 2477 Now
          </a>
        </div>

        <!-- Related posts -->
        {related.length > 0 && (
          <div class="mt-20 pt-12 border-t border-white/8">
            <h3 class="text-xl md:text-2xl font-extrabold text-white mb-7">More from the blog</h3>
            <div class="grid sm:grid-cols-3 gap-5">
              {related.map((p) => (
                <a
                  href={`${blogBase}/${p.slug}/`}
                  class="group bg-white/[0.03] border border-white/10 hover:border-amber-400/30 rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1"
                >
                  <div class="relative h-32 overflow-hidden">
                    <img
                      src={`${import.meta.env.BASE_URL}${p.data.image}`}
                      alt={p.data.title}
                      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#0B0B0B] via-transparent to-transparent opacity-70"></div>
                  </div>
                  <div class="p-4">
                    <h4 class="text-sm font-bold text-white leading-snug group-hover:text-amber-400 transition-colors line-clamp-2">
                      {p.data.title}
                    </h4>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .article-content :global(h2) {
    @apply text-2xl md:text-3xl font-extrabold text-white mt-12 mb-4 leading-tight;
  }
  .article-content :global(h3) {
    @apply text-xl md:text-2xl font-bold text-white mt-8 mb-3 leading-snug;
  }
  .article-content :global(p) {
    @apply text-white/60 text-base leading-relaxed mb-5;
  }
  .article-content :global(ul) {
    @apply space-y-2.5 mb-6;
  }
  .article-content :global(ol) {
    @apply space-y-2.5 mb-6 ml-5 list-decimal marker:text-amber-400 marker:font-bold;
  }
  .article-content :global(ol li) {
    @apply text-white/60 text-base leading-relaxed pl-1.5;
  }
  .article-content :global(ul li) {
    @apply relative text-white/60 text-base leading-relaxed pl-5;
  }
  .article-content :global(ul li::before) {
    content: '';
    @apply absolute left-0 top-[0.65em] w-2 h-2 rounded-full bg-amber-400/40;
  }
  .article-content :global(strong) {
    @apply text-white font-bold;
  }
  .article-content :global(a) {
    @apply text-amber-400 hover:text-amber-300 underline underline-offset-2 transition-colors;
  }
</style>
